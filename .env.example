# ─────────────────────────────────────────────────────────────
#  recon-cli · .env.example
#  Copia este fichero como .env y rellena los valores.
#  El .env nunca debe subirse al repositorio.
# ─────────────────────────────────────────────────────────────

# ── APIs externas (opcionales) ────────────────────────────────
SHODAN_API_KEY=
LEAKLOOKUP_API_KEY=
VIRUSTOTAL_API_KEY=
SECURITYTRAILS_API_KEY=
NVD_API_KEY=

# ── Parámetros de ejecución ───────────────────────────────────
REQUEST_TIMEOUT=10
MAX_SUBDOMAINS=500
DNS_THREADS=20
NMAP_PORTS=--top-ports 1000
LOG_LEVEL=INFO

# ── Informe PDF ───────────────────────────────────────────────
REPORT_AUTHOR=recon-cli
REPORT_OUTPUT_DIR=./reports/
REPORT_LOGO_PATH=

# ── Greybox (v1.2.0) — modo --scope greybox ──────────────────
#
# Opción A — Bearer token directo
#   Úsala cuando la API usa un token estático (API key, JWT preobtenido,
#   Tenant API Token tipo Namirial, etc.).
#   El token se envía directamente como: Authorization: Bearer <valor>
#
GREYBOX_TOKEN=
#
# Opción B — OAuth2 Client Credentials (intercambio automático)
#   Úsala cuando la API requiere intercambio client_id + client_secret
#   para obtener un access_token Bearer.
#   Si solo rellenas CLIENT_SECRET, el CLIENT_ID se pedirá interactivamente.
#   Si rellenas los dos, el intercambio es completamente automático.
#
GREYBOX_CLIENT_ID=
GREYBOX_CLIENT_SECRET=
GREYBOX_TOKEN_ENDPOINT=
#   ^ Dejar vacío para autodescubrir. Informar solo si el servidor
#     no expone /.well-known/openid-configuration ni paths OAuth2 estándar.
#     Ejemplo: https://auth.example.com/realms/myrealm/protocol/openid-connect/token
#
# ── Documentación de la API (opcional) ───────────────────────
GREYBOX_API_DOC=
#   ^ Ruta a colección Postman (.json) u OpenAPI (.yaml/.json).
#     Repetible desde CLI con --api-doc. Dejar vacío para usar solo el spider.
#
GREYBOX_ENV_FILE=
#   ^ Ruta al fichero de entorno Postman (.json) con variables
#     como base_url, service_id, etc. Solo necesario con colecciones Postman.
#
# ── Perfil de auditoría ───────────────────────────────────────
GREYBOX_PROFILE=normal
#   ^ normal     — 15 requests de rate limiting test (por defecto)
#     aggressive — 30 requests de rate limiting test
