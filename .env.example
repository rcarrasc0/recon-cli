# ─────────────────────────────────────────────────────────────
#  recon-cli · .env.example
#
#  Copia este fichero como .env y rellena tus valores reales:
#    cp .env.example .env
#
#  ⚠️  NUNCA subas .env a un repositorio. Está en .gitignore.
# ─────────────────────────────────────────────────────────────


# ── APIs de inteligencia ──────────────────────────────────────

# Shodan (https://account.shodan.io/)
SHODAN_API_KEY=

# Leak-Lookup (https://leak-lookup.com/account)
LEAKLOOKUP_API_KEY=


# ── APIs opcionales (dejar vacío si no se usan) ───────────────

# VirusTotal (https://www.virustotal.com/gui/my-apikey)
VIRUSTOTAL_API_KEY=

# SecurityTrails (https://securitytrails.com/app/account/credentials)
SECURITYTRAILS_API_KEY=


# ── NVD / NIST (CVEs) ─────────────────────────────────────────
# Sin key funciona pero con límite de rate. Key gratuita en:
# https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=


# ── Comportamiento del scanner ────────────────────────────────

# Timeout en segundos para conexiones HTTP/DNS (default: 10)
REQUEST_TIMEOUT=10

# Máximo de subdominios a resolver en fase de enumeración (default: 500)
MAX_SUBDOMAINS=500

# Hilos concurrentes para resolución DNS (default: 20)
DNS_THREADS=20

# Puertos nmap a escanear (default: top 1000; ejemplo extendido: 1-65535)
NMAP_PORTS=--top-ports 1000

# Nivel de verbosidad en consola: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO


# ── Informe PDF ───────────────────────────────────────────────

# Nombre de tu empresa/equipo (aparece en portada y pie de página)
REPORT_AUTHOR=

# Ruta donde guardar los informes generados (default: ./reports/)
REPORT_OUTPUT_DIR=./reports/

# Logotipo para la portada del informe (ruta a PNG/JPG, opcional)
REPORT_LOGO_PATH=
