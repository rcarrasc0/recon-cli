# ─────────────────────────────────────────────────────────────
#  recon-cli · .env.example
#  Copia como .env y rellena. Nunca subir el .env al repositorio.
# ─────────────────────────────────────────────────────────────

# ── APIs externas (opcionales) ────────────────────────────────
SHODAN_API_KEY=
LEAKLOOKUP_API_KEY=
VIRUSTOTAL_API_KEY=
SECURITYTRAILS_API_KEY=
NVD_API_KEY=

# ── Parámetros de ejecución ───────────────────────────────────
REQUEST_TIMEOUT=10
MAX_SUBDOMAINS=500
DNS_THREADS=20
NMAP_PORTS=--top-ports 1000
LOG_LEVEL=INFO

# ── Informe PDF ───────────────────────────────────────────────
REPORT_AUTHOR=recon-cli
REPORT_OUTPUT_DIR=./reports/
REPORT_LOGO_PATH=

# ── Greybox — modo --scope greybox ────────────────────────────
# GREYBOX_API_* → submodo [1] API audit.  GREYBOX_SSO_* → submodo [2] SSO.
# Detalle de cada campo: ver README.md, sección "Configuración Greybox".

GREYBOX_SUBMODE=
# ^ Salta el menú [1/2/3]. Valores: 1/api, 2/sso, 3/both.

# ─── API ───────────────────────────────────────────────────────
GREYBOX_API_TOKEN=
GREYBOX_API_CLIENT_ID=
GREYBOX_API_CLIENT_SECRET=
GREYBOX_API_TOKEN_ENDPOINT=
GREYBOX_API_DOC=
GREYBOX_API_ENV_FILE=
GREYBOX_API_PROFILE=normal

# ─── SSO ────────────────────────────────────────────────────────
GREYBOX_SSO_TOKEN=
GREYBOX_SSO_CLIENT_ID=
GREYBOX_SSO_CLIENT_SECRET=
GREYBOX_SSO_TOKEN_ENDPOINT=
